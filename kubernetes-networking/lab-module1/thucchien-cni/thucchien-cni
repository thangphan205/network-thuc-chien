#!/bin/bash
# =============================================================================
# ThucChienCNI — Custom CNI plugin viết bằng bash
# Khóa học: Network Thực Chiến · Kubernetes Networking
#
# Mục đích: Chứng minh CNI chỉ là một binary nhận env vars + stdin config,
# thực hiện thao tác OS, rồi trả JSON ra stdout. Không có gì huyền bí.
#
# Implements: ADD, DEL, CHECK, VERSION, STATUS (CNI spec v1.0.0)
# =============================================================================

set -e

# ─── Cấu hình mặc định (có thể override từ stdin config) ────────────────────
BRIDGE_NAME="tc0"                        # Bridge interface trên Node
SUBNET="10.88.0.0/24"                   # Dải IP cấp cho Pod
GATEWAY="10.88.0.1"                     # IP của bridge (default gateway của Pod)
PREFIX="24"
IPAM_DIR="/var/lib/thucchien-cni/ipam"  # Thư mục lưu state IPAM (ai đang giữ IP nào)

# ─── Logging (ra stderr — không làm nhiễu CNI JSON output ở stdout) ─────────
log() { echo "[ThucChienCNI] $*" >&2; }

# ─── Chuyển đổi IP ↔ integer (để tính IP kế tiếp trong subnet) ──────────────
ip_to_int() {
    local ip=$1
    IFS='.' read -r a b c d <<< "$ip"
    echo $(( (a << 24) + (b << 16) + (c << 8) + d ))
}

int_to_ip() {
    local n=$1
    echo "$(( (n >> 24) & 255 )).$(( (n >> 16) & 255 )).$(( (n >> 8) & 255 )).$(( n & 255 ))"
}

# ─── IPAM: Cấp IP ────────────────────────────────────────────────────────────
# Chiến lược: mỗi containerID có 1 file trong IPAM_DIR, nội dung = IP đã cấp
# Tương tự cách host-local IPAM của CNI chuẩn hoạt động
ipam_alloc() {
    local container_id=$1
    mkdir -p "$IPAM_DIR"

    # Idempotent: nếu container này đã được cấp IP, trả lại IP cũ
    if [ -f "$IPAM_DIR/$container_id" ]; then
        cat "$IPAM_DIR/$container_id"
        return 0
    fi

    # Tìm IP còn trống: bắt đầu từ .2 (.1 là gateway/bridge)
    local base_int
    base_int=$(ip_to_int "10.88.0.0")

    for i in $(seq 2 254); do
        local candidate
        candidate=$(int_to_ip $(( base_int + i )))

        # Kiểm tra IP này đã được cấp chưa
        local in_use=false
        for state_file in "$IPAM_DIR"/*; do
            [ -f "$state_file" ] || continue
            if [ "$(cat "$state_file")" = "$candidate" ]; then
                in_use=true
                break
            fi
        done

        if [ "$in_use" = false ]; then
            echo "$candidate" > "$IPAM_DIR/$container_id"
            echo "$candidate"
            return 0
        fi
    done

    log "ERROR: IP pool exhausted (all 253 IPs in $SUBNET đã được cấp)"
    exit 1
}

# ─── IPAM: Giải phóng IP ─────────────────────────────────────────────────────
# Idempotent: xóa file nếu tồn tại, không lỗi nếu đã xóa rồi
ipam_release() {
    local container_id=$1
    if [ -f "$IPAM_DIR/$container_id" ]; then
        local released_ip
        released_ip=$(cat "$IPAM_DIR/$container_id")
        rm -f "$IPAM_DIR/$container_id"
        log "Released IP $released_ip (container: ${container_id:0:12}...)"
    else
        log "IPAM: No state found for ${container_id:0:12}... (already released or never allocated)"
    fi
}

# ─── Đảm bảo bridge tc0 tồn tại ─────────────────────────────────────────────
ensure_bridge() {
    if ! ip link show "$BRIDGE_NAME" &>/dev/null; then
        log "Creating bridge $BRIDGE_NAME with IP $GATEWAY/$PREFIX"
        ip link add "$BRIDGE_NAME" type bridge
        ip link set "$BRIDGE_NAME" up
        ip addr add "$GATEWAY/$PREFIX" dev "$BRIDGE_NAME"
        # Bật IP forwarding để Pod có thể ra ngoài
        echo 1 > /proc/sys/net/ipv4/ip_forward
        # SNAT: Pod traffic ra ngoài sẽ dùng IP của Node
        iptables -t nat -A POSTROUTING -s "$SUBNET" ! -o "$BRIDGE_NAME" -j MASQUERADE 2>/dev/null || true
        log "Bridge $BRIDGE_NAME ready"
    fi
}

# ─── ADD: Cấp mạng cho Pod mới ───────────────────────────────────────────────
cmd_add() {
    local container_id="$CNI_CONTAINERID"
    local netns="$CNI_NETNS"          # Path đến network namespace: /var/run/netns/xxx hoặc /proc/PID/fd/N
    local ifname="${CNI_IFNAME:-eth0}" # Tên interface bên trong Pod (mặc định eth0)

    # 1. Cấp IP
    local pod_ip
    pod_ip=$(ipam_alloc "$container_id")
    log "ADD: container=${container_id:0:12}... ip=$pod_ip netns=$netns"

    # 2. Đảm bảo bridge tồn tại
    ensure_bridge

    # 3. Tạo veth pair
    #    host_veth: đầu nằm trên Node, gắn vào bridge tc0
    #    $ifname:   đầu nằm trong netns của Pod (eth0)
    local host_veth="vtc${container_id:0:8}"
    ip link add "$host_veth" type veth peer name "$ifname" netns "$netns"
    log "Created veth pair: $host_veth (host) <-> $ifname (pod)"

    # 4. Gắn host-side veth vào bridge và bật lên
    ip link set "$host_veth" master "$BRIDGE_NAME"
    ip link set "$host_veth" up

    # 5. Cấu hình interface bên trong Pod (dùng nsenter vì netns có thể là path)
    nsenter --net="$netns" -- ip addr add "$pod_ip/$PREFIX" dev "$ifname"
    nsenter --net="$netns" -- ip link set "$ifname" up
    nsenter --net="$netns" -- ip link set lo up
    nsenter --net="$netns" -- ip route add default via "$GATEWAY"
    log "Configured $ifname=$pod_ip/$PREFIX default-gw=$GATEWAY inside pod"

    # 6. Lấy MAC address của host_veth để điền vào CNI result
    local host_mac
    host_mac=$(cat "/sys/class/net/$host_veth/address")
    local pod_mac
    pod_mac=$(nsenter --net="$netns" -- cat "/sys/class/net/$ifname/address")

    # 7. Trả về CNI result JSON (bắt buộc theo spec)
    cat <<EOF
{
  "cniVersion": "1.0.0",
  "interfaces": [
    {
      "name": "$host_veth",
      "mac": "$host_mac",
      "sandbox": ""
    },
    {
      "name": "$ifname",
      "mac": "$pod_mac",
      "sandbox": "$netns"
    }
  ],
  "ips": [
    {
      "address": "$pod_ip/$PREFIX",
      "gateway": "$GATEWAY",
      "interface": 1
    }
  ],
  "routes": [
    { "dst": "0.0.0.0/0", "gw": "$GATEWAY" }
  ],
  "dns": {}
}
EOF
}

# ─── DEL: Thu hồi mạng của Pod bị xóa ───────────────────────────────────────
cmd_del() {
    local container_id="$CNI_CONTAINERID"
    log "DEL: container=${container_id:0:12}..."

    # 1. Giải phóng IP (idempotent)
    ipam_release "$container_id"

    # 2. Xóa host-side veth nếu còn tồn tại
    #    (nếu netns đã bị xóa, kernel tự xóa container-side, nhưng host-side vẫn còn)
    local host_veth="vtc${container_id:0:8}"
    if ip link show "$host_veth" &>/dev/null; then
        ip link del "$host_veth"
        log "Deleted veth $host_veth"
    else
        log "veth $host_veth not found (already cleaned up)"
    fi
    # DEL phải idempotent: không return error dù resource đã bị xóa
}

# ─── CHECK: Xác minh cấu hình mạng còn đúng ─────────────────────────────────
cmd_check() {
    local container_id="$CNI_CONTAINERID"
    local netns="$CNI_NETNS"

    # Kiểm tra IP có trong IPAM state không
    if [ ! -f "$IPAM_DIR/$container_id" ]; then
        log "CHECK FAIL: No IPAM state for ${container_id:0:12}..."
        exit 1
    fi

    local expected_ip
    expected_ip=$(cat "$IPAM_DIR/$container_id")

    # Kiểm tra IP có tồn tại trong netns không
    if ! nsenter --net="$netns" -- ip addr show dev "${CNI_IFNAME:-eth0}" | grep -q "$expected_ip"; then
        log "CHECK FAIL: $expected_ip not found in netns"
        exit 1
    fi

    log "CHECK OK: ${container_id:0:12}... ip=$expected_ip"
}

# ─── VERSION: Trả về các spec version plugin hỗ trợ ─────────────────────────
cmd_version() {
    cat <<'EOF'
{
  "cniVersion": "1.0.0",
  "supportedVersions": ["0.3.0", "0.3.1", "0.4.0", "1.0.0"]
}
EOF
}

# ─── STATUS: Kiểm tra plugin có sẵn sàng không ───────────────────────────────
cmd_status() {
    for cmd in ip nsenter iptables; do
        if ! command -v "$cmd" &>/dev/null; then
            log "STATUS FAIL: '$cmd' not found in PATH"
            exit 1
        fi
    done
    log "STATUS OK: all dependencies available"
    exit 0
}

# ─── Main dispatcher ─────────────────────────────────────────────────────────
# CNI spec: kubelet truyền config qua stdin (bắt buộc đọc, dù không dùng hết)
STDIN_CONFIG=$(cat)
log "CNI_COMMAND=$CNI_COMMAND container=${CNI_CONTAINERID:0:12}..."

case "${CNI_COMMAND}" in
    ADD)     cmd_add     ;;
    DEL)     cmd_del     ;;
    CHECK)   cmd_check   ;;
    VERSION) cmd_version ;;
    STATUS)  cmd_status  ;;
    *)
        log "ERROR: Unknown CNI_COMMAND='${CNI_COMMAND}'"
        cat <<EOF
{"code": 4, "msg": "unknown CNI_COMMAND: ${CNI_COMMAND}"}
EOF
        exit 4
        ;;
esac
